# WAF Project Environment Configuration
# Copy this to .env and customize values

# ============================================
# DATABASE
# ============================================
POSTGRES_USER=waf_user
POSTGRES_PASSWORD=waf_secure_password_change_me
POSTGRES_DB=waf_db

# For local development (SQLite)
# DATABASE_URL=sqlite:///./data/waf_dashboard.db

# For Docker (PostgreSQL)
# DATABASE_URL=postgresql://waf_user:waf_secure_password@postgres:5432/waf_db

# ============================================
# REDIS (REQUIRED for Block IP)
# ============================================
# Shared by gateway (rate limit, DDoS, blacklist) and backend (blacklist sync)
# Backend MUST have REDIS_URL for Block IP to work; startup fails visibly if sync cannot reach Redis
REDIS_URL=redis://localhost:6379

# ============================================
# API SETTINGS
# ============================================
API_HOST=0.0.0.0
API_PORT=3001
API_WORKERS=4

# WAF API auth (Feature 9): required for POST/PUT/DELETE on security-rules, bot, rate-limits
# Set to false to allow unauthenticated mutating calls (dev only)
API_AUTH_REQUIRED=true
# JWT (used by dashboard login). Required in production when ENV=production.
# Use a long random string (e.g. openssl rand -base64 32). If unset in dev, tokens reset on restart.
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRY=3600
# Optional: API key for automation/Terraform (header name and comma-separated keys)
# API_KEY_HEADER=X-API-Key
# API_KEYS=key1,key2

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ============================================
# WAF SETTINGS
# ============================================
WAF_ENABLED=true
WAF_THRESHOLD=0.65
WAF_FAIL_OPEN=true
WAF_TIMEOUT=5.0

# Custom model path (optional)
# WAF_MODEL_PATH=/app/models/waf-distilbert

# Production: fail startup if model missing (default false for dev)
# WAF_REQUIRE_MODEL=true

# ============================================
# WEBSOCKET
# ============================================
WEBSOCKET_ENABLED=true
WEBSOCKET_PING_INTERVAL=30

# ============================================
# DATA RETENTION (days)
# ============================================
METRICS_RETENTION_DAYS=30
TRAFFIC_RETENTION_DAYS=7
ALERTS_RETENTION_DAYS=90
THREATS_RETENTION_DAYS=90

# ============================================
# FRONTEND
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ============================================
# AUTH (NextAuth)
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars
# Server-side: Backend URL for credentials login (Docker: use http://backend:3001)
BACKEND_URL=http://localhost:3001

# Google OAuth - create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated list of email addresses that receive admin role when signing in with Google
# ADMIN_EMAILS=admin@example.com,ops@example.com

# Demo credentials (optional - defaults: admin@waf.example / admin123)
# ADMIN_EMAIL=admin@waf.example
# ADMIN_PASSWORD=admin123

# ============================================
# SERVICE URLS
# ============================================
FRONTEND_URL=http://localhost:3000
API_SERVER_URL=http://localhost:3001
WAF_SERVICE_URL=http://localhost:8000
JUICE_SHOP_URL=http://localhost:8080
WEBGOAT_URL=http://localhost:8081
DVWA_URL=http://localhost:8082

# ============================================
# ALERT NOTIFICATIONS (email)
# ============================================
# Leave SMTP_* unset to disable email alerts; Settings > Notifications still stored.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# ALERT_FROM_EMAIL=waf-alerts@example.com
# DASHBOARD_BASE_URL=http://localhost:3000

# ============================================
# AI AGENT — pick one provider (see limits below)
# ============================================
# Option A — Groq (free tier: 30 RPM, 14.4K RPD for llama-3.1-8b-instant)
GROQ_API_KEY=your_groq_api_key
# AGENT_MODEL=llama-3.1-8b-instant

# Option B — OpenAI (higher limits on paid tier; gpt-4o-mini is cheap)
# OPENAI_API_KEY=sk-your_openai_key
# AGENT_MODEL=gpt-4o-mini

# Option C — Other OpenAI-compatible (Together, vLLM, etc.)
# AGENT_API_KEY=your_provider_key
# AGENT_BASE_URL=https://api.together.xyz/v1
# AGENT_MODEL=meta-llama/Llama-3.2-3B-Instruct-Turbo

# Optional: raise if your provider allows (default 10). Groq free = 30 RPM total.
# AGENT_RATE_LIMIT_RPM=30
# AGENT_TIMEOUT_SECONDS=30

# ============================================
# WAF GATEWAY (Phase 1 — reverse proxy)
# ============================================
UPSTREAM_URL=http://localhost:3000
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
WAF_MODE=monitor
# WAF_ENABLED, WAF_THRESHOLD, WAF_FAIL_OPEN defined above
# Attack score thresholds (0-100). Score >= block threshold triggers 403.
# Challenge threshold (0 = disabled): score >= challenge but < block triggers challenge.
WAF_ATTACK_SCORE_BLOCK_THRESHOLD=70
WAF_ATTACK_SCORE_CHALLENGE_THRESHOLD=0
BODY_MAX_BYTES=10485760
PROXY_TIMEOUT=30.0
PROXY_MAX_CONNECTIONS=100

# Rate Limiting (Gateway)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BURST=20
RATE_LIMIT_FAIL_OPEN=true
# Rate limits are configured via env only (RATE_LIMIT_* above). Dynamic config from backend is not implemented.

# IP Blacklist (Gateway enforces; Backend syncs to Redis for B2B scale)
BLACKLIST_ENABLED=true
BLACKLIST_TENANT_ID=default
# Backend REQUIRES REDIS_URL to sync blacklist; Block IP returns 503 if Redis unavailable

# DDoS Protection (Gateway)
DDOS_ENABLED=true
DDOS_MAX_BODY_BYTES=10485760
DDOS_BURST_THRESHOLD=50
DDOS_BURST_WINDOW_SECONDS=5
DDOS_BLOCK_DURATION_SECONDS=60
DDOS_FAIL_OPEN=true

# Adaptive DDoS (Feature 6): learn baseline from traffic, auto-tune burst threshold in Redis
# ADAPTIVE_DDOS_ENABLED=false
# ADAPTIVE_DDOS_LEARNING_WINDOW_MINUTES=60
# ADAPTIVE_DDOS_PERCENTILE=95
# ADAPTIVE_DDOS_MULTIPLIER=1.5
# ADAPTIVE_DDOS_THRESHOLD_MIN=20
# ADAPTIVE_DDOS_THRESHOLD_MAX=500
# ADAPTIVE_DDOS_UPDATE_INTERVAL_MINUTES=15
# ADAPTIVE_DDOS_REDIS_KEY=waf:ddos:adaptive_threshold
# ADAPTIVE_DDOS_REDIS_KEY_META=waf:ddos:adaptive_meta
# Gateway: same REDIS_URL; reads threshold from Redis; ADAPTIVE_DDOS_REFRESH_SECONDS=60

# Credential leak protection (Feature 7 — HIBP k-anonymity)
# CREDENTIAL_LEAK_ENABLED=false
# CREDENTIAL_LEAK_API_URL=https://api.pwnedpasswords.com/range/
# CREDENTIAL_LEAK_API_KEY=
# CREDENTIAL_LEAK_LOGIN_PATHS=/login,/api/auth/login
# CREDENTIAL_LEAK_PASSWORD_FIELD=password
# CREDENTIAL_LEAK_USERNAME_FIELD=username
# CREDENTIAL_LEAK_ACTION=block
# CREDENTIAL_LEAK_TIMEOUT_SECONDS=5
# Gateway: CREDENTIAL_LEAK_BACKEND_URL=http://localhost:3001
# CREDENTIAL_LEAK_BODY_MAX_BYTES=65536
# CREDENTIAL_LEAK_FAIL_OPEN=true

# Bot Management (Gateway -> Backend scoring)
BOT_ENABLED=true
# Backend base URL for POST /api/bot/score (empty = use local scoring when implemented)
BOT_BACKEND_URL=http://localhost:3001
BOT_FAIL_OPEN=true
BOT_TIMEOUT_SECONDS=1.0
BOT_CHALLENGE_RETRY_AFTER=60

# Bot Management (Backend)
# Optional URL to sync verified bots (JSON array of {name, pattern}); empty = disabled
# BOT_VERIFIED_SYNC_URL=
BOT_VERIFIED_SYNC_CRON=0 */6 * * *
BOT_DEFAULT_SCORE_UNKNOWN=50
BOT_BAND_BLOCK_MAX=29
BOT_BAND_CHALLENGE_MAX=69
# Bot scores (1-99): verified/whitelisted, missing UA, behavioral, signature-matched
BOT_SCORE_VERIFIED=95
BOT_SCORE_MISSING_UA=25
BOT_SCORE_BEHAVIORAL=25
BOT_SCORE_SIGNATURE_MATCHED=34

# Event reporting (Gateway -> Backend). Events are batched and POSTed in bulk.
# IMPORTANT: For dashboard rate-limit/DDoS/WAF metrics, you must set BACKEND_EVENTS_URL
# and BACKEND_EVENTS_ENABLED=true. If BACKEND_EVENTS_URL is empty, the gateway sends no events.
# Local: http://localhost:3001/api/events/ingest  | Docker: http://backend:3001/api/events/ingest
BACKEND_EVENTS_URL=http://localhost:3001/api/events/ingest
BACKEND_EVENTS_ENABLED=true
EVENTS_BATCH_SIZE=50
EVENTS_BATCH_INTERVAL_SECONDS=2.0

# ============================================
# GATEWAY -> BACKEND URLS (set when feature is enabled)
# ============================================
# Bot scoring: gateway calls backend POST /api/bot/score. Local: http://localhost:3001 | Docker: http://backend:3001
# BOT_BACKEND_URL=http://localhost:3001
# Upload scanning: gateway sends uploads to backend. Set UPLOAD_SCAN_BACKEND_URL when UPLOAD_SCAN_ENABLED=true
# UPLOAD_SCAN_BACKEND_URL=http://localhost:3001
# Firewall for AI: gateway calls backend for LLM path checks. Set FIREWALL_AI_BACKEND_URL when FIREWALL_AI_ENABLED=true
# FIREWALL_AI_BACKEND_URL=http://localhost:3001
# Credential leak: gateway calls backend for HIBP check. Set CREDENTIAL_LEAK_BACKEND_URL when CREDENTIAL_LEAK_ENABLED=true
# CREDENTIAL_LEAK_BACKEND_URL=http://localhost:3001
# Managed rules: gateway fetches rules from backend. Set MANAGED_RULES_BACKEND_URL when MANAGED_RULES_ENABLED=true
# MANAGED_RULES_BACKEND_URL=http://localhost:3001

# MongoDB (Gateway event store — Phase 2)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=waf_gateway
EVENT_RETENTION_DAYS=30
WAF_BODY_INSPECT_MAX=1048576

# ============================================
# MANAGED RULES (OWASP CRS + feed sync)
# ============================================
# Backend: feed URL (built-in sample feed for local/demo; use empty or external URL as needed)
MANAGED_RULES_FEED_URL=http://localhost:3001/api/rules/managed/feed
# MANAGED_RULES_FEED_FORMAT=json
# MANAGED_RULES_UPDATE_INTERVAL_HOURS=24
# MANAGED_RULES_PACK_ID=owasp_crs
# Optional: Authorization header for feed (e.g. Bearer token)
# MANAGED_RULES_FEED_HEADER=

# Gateway: fetch rules from backend and evaluate on request
# MANAGED_RULES_ENABLED=false
# MANAGED_RULES_BACKEND_URL=http://localhost:3001
# MANAGED_RULES_CACHE_TTL_SECONDS=300
# MANAGED_RULES_FAIL_OPEN=true

# ============================================
# MALICIOUS UPLOAD SCANNING (Feature 4)
# ============================================
# Backend: scan engine (ClamAV socket or cloud API). Gateway buffers uploads and calls backend /api/scan/upload.
# UPLOAD_SCAN_ENABLED=false
# UPLOAD_SCAN_ENGINE=clamav
# CLAMAV_SOCKET=
# CLAMAV_TIMEOUT_SECONDS=30
# UPLOAD_SCAN_CLOUD_URL=
# UPLOAD_SCAN_CLOUD_API_KEY=
# UPLOAD_SCAN_POLICY_INFECTED=block
# UPLOAD_SCAN_QUARANTINE_DIR=
# UPLOAD_SCAN_MAX_FILE_BYTES=52428800
# UPLOAD_SCAN_PATH_PREFIXES=
# UPLOAD_SCAN_SKIP_IF_OVER_MAX=true

# Gateway: where to send file for scan (backend base URL)
# UPLOAD_SCAN_BACKEND_URL=http://localhost:3001
# UPLOAD_SCAN_TIMEOUT_SECONDS=30

# ============================================
# FIREWALL FOR AI (Feature 5 — LLM endpoint protection)
# ============================================
# Backend: prompt-injection / PII patterns from DB and optional URLs; abuse rate limit per IP.
# FIREWALL_AI_ENABLED=false
# FIREWALL_AI_PROMPT_PATTERNS_URL=
# FIREWALL_AI_PII_PATTERNS_URL=
# FIREWALL_AI_ACTION_PROMPT_MATCH=block
# FIREWALL_AI_ACTION_PII=log
# FIREWALL_AI_ABUSE_RATE_PER_MINUTE=60
# FIREWALL_AI_PATTERNS_REFRESH_SECONDS=300

# Gateway: call backend evaluate for LLM-labeled paths
# FIREWALL_AI_BACKEND_URL=http://localhost:3001
# FIREWALL_AI_TIMEOUT=5.0
# FIREWALL_AI_FAIL_OPEN=true
# FIREWALL_AI_CACHE_TTL_SECONDS=60

# ============================================
# CONTINUOUS LEARNING (Phase 8)
# ============================================
# LEARNING_ENABLED=true
# LOG_PATH=/var/log/nginx/access.log
# LEARNING_UPDATE_INTERVAL_HOURS=24

# ============================================
# PROMETHEUS METRICS (Feature 10)
# ============================================
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_METRICS_NAMESPACE=waf
# GET /metrics returns text exposition; data from security_events (last 60 min).

# ============================================
# ALERTING AND WEBHOOKS (Feature 10)
# ============================================
# No default webhook URL; set in env or via Settings > Alerting
# ALERT_WEBHOOK_URL=
# ALERT_WEBHOOK_HEADERS=
# Optional JSON or key:value,key:value for webhook request headers
# Alert rules (override in DB/settings)
# ALERT_RULE_BLOCK_RATE_THRESHOLD=0.1
# ALERT_RULE_BLOCK_RATE_WINDOW_MINUTES=5
# ALERT_RULE_DDOS_COUNT_THRESHOLD=100
# ALERT_EVALUATION_INTERVAL_SECONDS=60

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_INGESTION_ENABLED=true
