# WAF Project Environment Configuration
# Copy this to .env and customize values

# ============================================
# DATABASE
# ============================================
POSTGRES_USER=waf_user
POSTGRES_PASSWORD=waf_secure_password_change_me
POSTGRES_DB=waf_db

# For local development (SQLite)
# DATABASE_URL=sqlite:///./data/waf_dashboard.db

# For Docker (PostgreSQL)
# DATABASE_URL=postgresql://waf_user:waf_secure_password@postgres:5432/waf_db

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# API SETTINGS
# ============================================
API_HOST=0.0.0.0
API_PORT=3001
API_WORKERS=4

# ============================================
# CORS
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ============================================
# WAF SETTINGS
# ============================================
WAF_ENABLED=true
WAF_THRESHOLD=0.65
WAF_FAIL_OPEN=true
WAF_TIMEOUT=5.0

# Custom model path (optional)
# WAF_MODEL_PATH=/app/models/waf-distilbert

# ============================================
# WEBSOCKET
# ============================================
WEBSOCKET_ENABLED=true
WEBSOCKET_PING_INTERVAL=30

# ============================================
# DATA RETENTION (days)
# ============================================
METRICS_RETENTION_DAYS=30
TRAFFIC_RETENTION_DAYS=7
ALERTS_RETENTION_DAYS=90
THREATS_RETENTION_DAYS=90

# ============================================
# FRONTEND
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ============================================
# AUTH (NextAuth)
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-at-least-32-chars

# Google OAuth - create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Demo credentials (optional - defaults: admin@waf.example / admin123)
# ADMIN_EMAIL=admin@waf.example
# ADMIN_PASSWORD=admin123

# ============================================
# SERVICE URLS
# ============================================
FRONTEND_URL=http://localhost:3000
API_SERVER_URL=http://localhost:3001
WAF_SERVICE_URL=http://localhost:8000
JUICE_SHOP_URL=http://localhost:8080
WEBGOAT_URL=http://localhost:8081
DVWA_URL=http://localhost:8082

# ============================================
# ALERT NOTIFICATIONS (email)
# ============================================
# Leave SMTP_* unset to disable email alerts; Settings > Notifications still stored.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# ALERT_FROM_EMAIL=waf-alerts@example.com
# DASHBOARD_BASE_URL=http://localhost:3000

# ============================================
# AI AGENT — pick one provider (see limits below)
# ============================================
# Option A — Groq (free tier: 30 RPM, 14.4K RPD for llama-3.1-8b-instant)
GROQ_API_KEY=your_groq_api_key
# AGENT_MODEL=llama-3.1-8b-instant

# Option B — OpenAI (higher limits on paid tier; gpt-4o-mini is cheap)
# OPENAI_API_KEY=sk-your_openai_key
# AGENT_MODEL=gpt-4o-mini

# Option C — Other OpenAI-compatible (Together, vLLM, etc.)
# AGENT_API_KEY=your_provider_key
# AGENT_BASE_URL=https://api.together.xyz/v1
# AGENT_MODEL=meta-llama/Llama-3.2-3B-Instruct-Turbo

# Optional: raise if your provider allows (default 10). Groq free = 30 RPM total.
# AGENT_RATE_LIMIT_RPM=30
# AGENT_TIMEOUT_SECONDS=30

# ============================================
# WAF GATEWAY (Phase 1 — reverse proxy)
# ============================================
UPSTREAM_URL=http://localhost:3000
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
WAF_MODE=monitor
# WAF_ENABLED, WAF_THRESHOLD, WAF_FAIL_OPEN defined above
BODY_MAX_BYTES=10485760
PROXY_TIMEOUT=30.0
PROXY_MAX_CONNECTIONS=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_INGESTION_ENABLED=true
